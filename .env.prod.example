# ÜRETİM ortam değişkenleri — VPS'te bu dosyayı `.env` olarak kopyalayıp doldurun.
# (docker compose, aynı dizindeki .env dosyasını otomatik okur.)

# Alan adınız (DNS A kaydı VPS IP'sine yönlendirilmeli). Caddy buraya HTTPS alır.
# Hem apex hem www için (boşlukla ayrılır):
DOMAIN=omnitraceglobal.com www.omnitraceglobal.com

# Güçlü bir veritabanı parolası
POSTGRES_PASSWORD=degistir-guclu-bir-parola

# Uzun, rastgele bir JWT gizli anahtarı (örn: openssl rand -hex 32)
JWT_SECRET=degistir-cok-uzun-rastgele-bir-anahtar

# Cihaz ingest anahtarı (opsiyonel). Doldurursanız STM32/ESP32 isteğinde
# "x-device-token" başlığını göndermeli — boş bırakırsanız ingest açık olur.
INGEST_TOKEN=
