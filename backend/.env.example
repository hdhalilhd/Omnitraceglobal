# Backend ortam değişkenleri — bu dosyayı `.env` olarak kopyalayın
NODE_ENV=development
PORT=4000

# PostgreSQL + TimescaleDB (docker-compose ile aynı kimlikler)
DATABASE_URL="postgresql://forklift:forklift_dev_pass@localhost:5432/forklift?schema=public"

# JWT
JWT_SECRET="degistir-bu-gizli-anahtari-prod-da"
JWT_EXPIRES_IN="12h"

# MQTT broker
MQTT_URL="mqtt://localhost:1883"
MQTT_USERNAME=""
MQTT_PASSWORD=""

# CORS — frontend origin
CORS_ORIGIN="http://localhost:5173"
