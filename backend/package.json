{
  "name": "forklift-telemetri-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Elektrikli forklift telemetri — backend (MQTT ingest + REST + WebSocket)",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "simulate": "tsx src/simulator.ts",
    "broker": "tsx src/broker.ts",
    "test": "vitest run",
    "db:push": "prisma db push",
    "db:plainpg": "tsx prisma/applyPlainPg.ts",
    "db:setup:local": "prisma db push && npm run db:plainpg && npm run db:seed",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:timescale": "tsx prisma/applyTimescale.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma migrate deploy && npm run db:timescale && npm run db:seed",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "aedes": "^0.51.3",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mqtt": "^5.10.3",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
